{
  "description": "Validates names against SOUL naming rules using string tokenizer and count loops",
  "package_name": "enforce-naming-rules-json-name",
  "module_name": "enforce-naming-rules-json-name",
  "imports": ["runtime-for-generated-ipm-code"],
  "function_definitions": {
    "main": {
      "return_type": "int",
      "execution_instructions": [
        {"instruction_type": "variable_declaration", "variable_name": "name", "variable_type": "string", "assignment_operation": "literal", "literal_value": "test-service-name-for-test"},
        {"instruction_type": "variable_declaration", "variable_name": "result", "variable_type": "int", "assignment_operation": "literal", "literal_value": "0"},
        {"instruction_type": "function_invocation", "invocation_name": "validate_name_against_soul_rules", "invocation_arguments": {"a1": "name"}, "result_assignment_variable": "result", "result_type": "int"},
        {"instruction_type": "return_statement", "return_payload": {"value": "result"}}
      ]
    },
    "validate_name_against_soul_rules": {
      "return_type": "int",
      "parameter_definitions": [
        {"parameter_name": "name", "parameter_type": "string"}
      ],
      "execution_instructions": [
        {"instruction_type": "conditional_branch", "condition_operation": "string_equals", "condition_target": "name", "condition_value": "main",
          "branch_on_success": [
            {"instruction_type": "return_statement", "return_payload": {"value": "0"}}
          ]
        },
        {"instruction_type": "variable_declaration", "variable_name": "wcount", "variable_type": "int", "assignment_operation": "literal", "literal_value": "0"},
        {"instruction_type": "string_tokenizer_loop", "source_string": "name", "separator": "-", "token_variable": "word",
          "body_instructions": [
            {"instruction_type": "variable_declaration", "variable_name": "wcount", "variable_type": "int", "assignment_operation": "increment", "source_target": "wcount"},
            {"instruction_type": "conditional_branch", "condition_operation": "is_not_null", "condition_target": "word",
              "branch_on_success": [
                {"instruction_type": "conditional_branch", "condition_operation": "string_equals", "condition_target": "word", "condition_value": "service",
                  "branch_on_success": [
                    {"instruction_type": "return_statement", "return_payload": {"execution_status": "failure", "error_code": "BANNED WORD: 'service' is a banned type word\n  → replace with a word describing WHAT it does"}}
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}
