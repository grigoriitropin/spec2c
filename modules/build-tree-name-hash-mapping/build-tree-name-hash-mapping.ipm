{"package_name": "build-tree-name-hash-mapping", "build_type": "library", "module_name": "build-tree-name-hash-mapping", "description": "Merkle tree mapping logical names to content hashes. CHW-Register merge: when two agents write same name, closest agent-hash to name-hash wins. Deterministic, lock-free, commutative. Tree content is line-based: name:hash\\n.", "extern_imports": [{"name": "read_entire_file_into_string", "return_type": "str", "arguments": [{"name": "path", "type": "str"}]}, {"name": "write_text_string_into_file", "return_type": "void", "arguments": [{"name": "path", "type": "str"}, {"name": "content", "type": "str"}]}], "function_definitions": {"merge_trees_using_chw_method": {"return_type": "str", "parameter_definitions": [{"parameter_name": "tree_a", "parameter_type": "str"}, {"parameter_name": "tree_b", "parameter_type": "str"}], "execution_instructions": []}, "insert_name_tree_hash_mapping": {"return_type": "str", "parameter_definitions": [{"parameter_name": "tree_content", "parameter_type": "str"}, {"parameter_name": "name", "parameter_type": "str"}, {"parameter_name": "blob_hash", "parameter_type": "str"}], "execution_instructions": []}, "lookup_name_tree_hash_mapping": {"return_type": "str", "parameter_definitions": [{"parameter_name": "tree_content", "parameter_type": "str"}, {"parameter_name": "name", "parameter_type": "str"}], "execution_instructions": []}}}