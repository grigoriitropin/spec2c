#!/usr/bin/env bash
# spec2c pre-commit hook — strict validation gate
set -euo pipefail

RED='\033[31m'
GREEN='\033[32m'
NC='\033[0m'
errors=0

check() {
    local msg="$1"; shift
    if "$@"; then
        printf "${GREEN}OK${NC} %s\n" "$msg"
    else
        printf "${RED}FAIL${NC} %s\n" "$msg"
        errors=$((errors + 1))
    fi
}

SRC=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|h)$' || true)
SPEC=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ipm|json)$' | grep -v 'flake\.lock' || true)
ALL=$(git diff --cached --name-only --diff-filter=ACM || true)

echo "=== spec2c pre-commit gate ==="

# 1. Forbidden patterns in C source
if [ -n "$SRC" ]; then
    check "no 2>/dev/null" \
        sh -c "! grep -l '2>/dev/null' $SRC 2>/dev/null | grep -q ."
    check "no /tmp/ in paths" \
        sh -c "! grep -l '\"/tmp/' $SRC 2>/dev/null | grep -q ."
    check "all nix build use --no-link" \
        sh -c "! grep -h '\"nix build' $SRC 2>/dev/null | grep -v '\--no-link' | grep -q ."
fi

# 2. SPDX headers on C/H files
for f in $SRC; do
    check "$f: SPDX header" grep -q 'SPDX-License-Identifier' "$f"
done

# 3. No PRAGMAs without comment justification
for f in $SRC; do
    if grep -q '_Pragma.*ignored' "$f" 2>/dev/null; then
        check "$f: PRAGMA justified" \
            grep -B1 '_Pragma.*ignored' "$f" | grep -qE '(truncation|format|unused|overflow)'
    fi
done

# 4. .ipm and .spec.json validation
for f in $SPEC; do
    if [ -f "$f" ]; then
        check "$f: valid JSON" python3 -c "import json; json.load(open('$f'))"
    fi
done

# 5. No result symlink tracked
check "no ./result tracked" sh -c "! git diff --cached --name-only | grep -q '^result'"

echo
if [ $errors -eq 0 ]; then
    printf "${GREEN}All checks passed ($errors errors)${NC}\n"
    exit 0
else
    printf "${RED}$errors check(s) failed${NC}\n"
    exit 1
fi
