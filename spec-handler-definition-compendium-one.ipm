              "code_format": "{\n",
              "code_arguments": []
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "  char _buf[256]; snprintf(_buf, sizeof(_buf), \"%%s\", %s);\n",
              "code_arguments": [
                "src"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "  char *_save;\n",
              "code_arguments": []
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "  for (char *_t = strtok_r(_buf, %s, &_save); _t; _t = strtok_r(NULL, %s, &_save)) {\n",
              "code_arguments": [
                "sep",
                "sep"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "    const char *%s = _t;\n",
              "code_arguments": [
                "tok"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "    cJSON *body_%s = cJSON_GetObjectItemCaseSensitive(inst, \"body_instructions\");\n",
              "code_arguments": [
                "src"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "    if (body_%s) generate_code_from_ast_instructions(body_%s, out, indent + 1, return_type);\n",
              "code_arguments": [
                "src",
                "src"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "  }\n",
              "code_arguments": []
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "}\n",
              "code_arguments": []
            }
          ]
        },
