          "field_name": "field_name"
        },
        {
          "instruction_type": "conditional_branch",
          "condition_operation": "is_not_null",
          "condition_target": "vn",
          "branch_on_success": [
            {
              "instruction_type": "conditional_branch",
              "condition_operation": "string_equals",
              "condition_target": "vt",
              "condition_value": "string",
              "branch_on_success": [
                {
                  "instruction_type": "emit_formatted_code",
                  "code_format": "const char *%s = cJSON_GetObjectItemCaseSensitive(%s,\"%s\") ? cJSON_GetObjectItemCaseSensitive(%s,\"%s\")->valuestring : \"\";\n",
                  "code_arguments": [
                    "vn",
                    "so",
                    "fn",
                    "so",
                    "fn"
                  ]
                }
              ],
              "branch_on_failure": [
                {
                  "instruction_type": "emit_formatted_code",
                  "code_format": "cJSON *%s = cJSON_GetObjectItemCaseSensitive(%s, \"%s\");\n",
                  "code_arguments": [
                    "vn",
                    "so",
                    "fn"
                  ]
                }
              ]
            }
          ]
        },
        {
          "instruction_type": "return_statement",
          "return_payload": {
            "value": "0"
          }
        }
      ]
    },
