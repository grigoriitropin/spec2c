      ],
      "execution_instructions": [
        {
          "instruction_type": "access_json_field",
          "variable_name": "col",
          "variable_type": "string",
          "source_object": "inst",
          "field_name": "collection_variable"
        },
        {
          "instruction_type": "access_json_field",
          "variable_name": "itm",
          "variable_type": "string",
          "source_object": "inst",
          "field_name": "item_variable"
        },
        {
          "instruction_type": "conditional_branch",
          "condition_operation": "is_not_null",
          "condition_target": "col",
          "branch_on_success": [
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "for (int _i_%s = 0; _i_%s < cJSON_GetArraySize(%s); _i_%s++) {\n",
              "code_arguments": [
                "col",
                "col",
                "col",
                "col"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "  cJSON *%s = cJSON_GetArrayItem(%s, _i_%s);\n",
              "code_arguments": [
                "itm",
                "col",
                "col"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "  cJSON *body_%s = cJSON_GetObjectItemCaseSensitive(inst, \"body_instructions\");\n",
              "code_arguments": [
                "col"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "  if (body_%s) generate_code_from_ast_instructions(body_%s, out, indent + 1, return_type);\n",
              "code_arguments": [
                "col",
                "col"
              ]
            },
            {
              "instruction_type": "emit_formatted_code",
              "code_format": "}\n",
              "code_arguments": []
            }
          ]
        },
        {
          "instruction_type": "return_statement",
          "return_payload": {
            "value": "0"
          }
        }
      ]
    },
